@baseUrl = http://localhost:8080

###
# POST — Cadastrar evento
POST {{baseUrl}}/api/eventos
Content-Type: application/json

{
  "titulo": "Semana Academica: Abertura",
  "descricao": "Abertura oficial da semana academica com apresentacao da programacao.",
  "palestrante": "Coordenacao Academica",
  "emailContato": "academico@escola.edu.br",
  "cargaHoraria": 2,
  "dataEvento": "2026-06-01",
  "quantidadeVagas": 200,
  "valorInscricao": 0.00,
  "status": "ABERTO"
}

###
# GET ALL — Listar todos
GET {{baseUrl}}/api/eventos

###
# GET — Buscar por ID (ajuste o ID)
GET {{baseUrl}}/api/eventos/1

###
# PUT — Atualizar por ID (payload igual ao POST)
PUT {{baseUrl}}/api/eventos/1
Content-Type: application/json

{
  "titulo": "Semana Academica: Abertura (Atualizado)",
  "descricao": "Abertura oficial com ajustes de horario e local.",
  "palestrante": "Coordenacao Academica",
  "emailContato": "academico@escola.edu.br",
  "cargaHoraria": 2,
  "dataEvento": "2026-06-01",
  "quantidadeVagas": 220,
  "valorInscricao": 0.00,
  "status": "ABERTO"
}

###
# DELETE — Remover por ID (ajuste o ID)
DELETE {{baseUrl}}/api/eventos/1

